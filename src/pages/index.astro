---
import Layout from "../layouts/Layout.astro";
import Popup from "../components/Popup.astro";
---

<Layout>
  <audio id="bg-music" src="/assets/music/curious-creatures.mp3" loop></audio>
  <audio id="click" src="/assets/music/mouse-click.mp3"></audio>
  <audio id="miau" src="/assets/music/miau.mp3"></audio>
  <div class="mx-32">
    <img
      id="submissions"
      src="/assets/submissions-1.png"
      class="justify-center fixed top-[40vh] left-[28vw] transition-all scale-[0.8] hover:scale-[1.00]"
    />
    <img
      id="faq"
      src="/assets/faq-1.png"
      class="justify-center fixed top-[20vh] right-[20vw] transition-all scale-[0.8] hover:scale-[1.00]"
    />
    <img
      id="ideas"
      src="/assets/ideas-1.png"
      class="justify-center fixed top-[40vh] right-[28vw] transition-all scale-[0.8] hover:scale-[1.00]"
    />
    <img
      id="box"
      src="/assets/box-1.png"
      class="justify-center fixed top-[20vh] left-[20vw] transition-all scale-[0.8] hover:scale-[1.00]"
    />
    <a
      href="https://www.discovermagazine.com/meet-10-of-the-worlds-most-adorable-frogs-44995"
      class="justify-center top-[55vh] left-[50vw] -translate-x-1/2 -translate-y-1/2 fixed transition-all scale-[0.9] hover:scale-[1.00]"
    >
      <img
        id="frog"
        src="/assets/frog-1.png"
        class="justify-self-center"
      />
    </a>
  </div>

  <Popup
    id="open-submissions"
    background="/assets/open-submissions.png"
    classAdd="top-[50vh] left-[25vh] -translate-x-1/2 -translate-y-1/2"
  />
  <Popup
    id="open-faq"
    background="/assets/open-faq.png"
    classAdd="top-[50vh] -right-[18vh] -translate-x-1/2 -translate-y-1/2"
  />
  <!--box-->
  <Popup
    id="open-figurine"
    background="/assets/open-figurine.png"
    classAdd="top-[18vh] left-[37vw] scale-[0.9] -translate-x-1/2 -translate-y-1/2"
  />
  <Popup
    id="open-keycap"
    background="/assets/open-keycap.png"
    classAdd="top-[35vh] left-[15vw] scale-[0.9] -translate-x-1/2 -translate-y-1/2"
  />
  <Popup
    id="open-stickers"
    background="/assets/open-stickers.png"
    classAdd="top-[15vh] left-[23.5vw] scale-[0.9] -translate-x-1/2  -translate-y-1/2"
  />
  <Popup
    id="open-surprise"
    background="/assets/open-surprise.png"
    classAdd="top-[57vh] left-[22vw] scale-[0.9] -translate-x-1/2 scale-[0.9] -translate-y-1/2"
  />
  <!--end of box -->
  <!--YOU NEED TO DRAW ideasss!!!!!!!!!!!-->

  <script>
    const submissions = document.getElementById(
      "submissions",
    ) as HTMLImageElement;
    const faq = document.getElementById("faq") as HTMLImageElement;
    const ideas = document.getElementById("ideas") as HTMLImageElement;
    const box = document.getElementById("box") as HTMLImageElement;
    const frog = document.getElementById("frog") as HTMLImageElement;

    const openSubmissions = document.getElementById(
      "open-submissions",
    ) as HTMLElement;
    const openFAQ = document.getElementById("open-faq") as HTMLElement;
    const openFigurine = document.getElementById("open-figurine") as HTMLElement;
    const openKeycap = document.getElementById("open-keycap") as HTMLElement;
    const openStickers= document.getElementById("open-stickers") as HTMLElement;
    const openSurprise = document.getElementById("open-surprise") as HTMLElement;

    const bgMusic = document.getElementById("bg-music") as HTMLAudioElement;
    const clickSFX = document.getElementById("click") as HTMLAudioElement;
    const miauSFX = document.getElementById("miau") as HTMLAudioElement;
    let musicStarted = false;

    const bgPath1 = "url(/assets/whimsy-bg-1.png)";
    const bgPath2 = "url(/assets/whimsy-bg-2.png)";
    let count = 1;

    //start bg music
    document.addEventListener("click", () => {
      if (!musicStarted) {
        musicStarted = true;
        bgMusic.volume = 0.1;
        bgMusic.play();
      }
    });

    //hover animations
    function makeHoverable(
      element: HTMLImageElement,
      image1: string,
      image2: string,
    ) {
      element?.addEventListener("mouseenter", () => {
        element.src = image2;
        miauSFX.pause();
        miauSFX.play();
      });
      element?.addEventListener("mouseleave", () => {
        element.src = image1;
      });
    }

    makeHoverable(
      submissions,
      "/assets/submissions-1.png",
      "/assets/submissions-2.png",
    );

    makeHoverable(faq, "/assets/faq-1.png", "assets/faq-2.png");
    makeHoverable(ideas, "/assets/ideas-1.png", "assets/ideas-2.png");
    makeHoverable(box, "/assets/box-1.png", "assets/box-2.png");
    makeHoverable(frog, "/assets/frog-1.png", "assets/frog-2.png");

    //make click popup
    function makeClickable(element: HTMLImageElement, popups: HTMLElement[]) {
      element?.addEventListener("click", () => {
        clickSFX.play();
        popups.forEach((popup) => {
          popup?.classList.toggle("hidden");
        });
      });
    }

    makeClickable(submissions, [openSubmissions]);
    makeClickable(faq, [openFAQ]);
    makeClickable(box, [openFigurine, openKeycap, openStickers, openSurprise]);

    frog?.addEventListener("click", () => {
      clickSFX.play();
    });

    setInterval(() => {
      count += 1;
      count %= 2;
      if (count == 0) {
        document.body.style.backgroundImage = bgPath1;
      } else {
        document.body.style.backgroundImage = bgPath2;
      }
    }, 500);

    function makeDraggable(popup: HTMLElement) {
      let isDragging = false;
      let offsetX = 0;
      let offsetY = 0;

      popup?.addEventListener("mousedown", (e: MouseEvent) => {
        e.preventDefault();
        isDragging = true;
        const rect = popup.getBoundingClientRect();
        offsetX = e.clientX - rect.left*0.5 - rect.right*0.5;
        offsetY = e.clientY - rect.top*0.5 - rect.bottom*0.5;
      });

      document.addEventListener("mousemove", (e: MouseEvent) => {
        if (!isDragging) return;
        popup.style.left = `${e.clientX - offsetX}px`;
        popup.style.top = `${e.clientY - offsetY}px`;
      });

      document.addEventListener("mouseup", (e: MouseEvent) => {
        isDragging = false;
      });
    }

    //make all popups on the page draggable
    const popups = document.querySelectorAll<HTMLElement>(".popup");
    popups.forEach((popup) => {
      makeDraggable(popup);
    });
  </script>
</Layout>
