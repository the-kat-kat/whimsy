---
const {id, title} = Astro.props;
---

<div id={id} class="popup hidden fixed top-1/4 left-1/3 z-50 w-80 bg-white rounded-xl shadow-xl">
    <div class="popup-handle cursor-move bg-gray-200 rounded-t-xl px-4 py-2 flex justify-between items-center">
        <span>{title}</span>
        <button class="popup-close">
            <img src="/images/yt-icon.png" alt="close" class="w-4 h-4"/>
        </button>
    </div>

    <div class="p-4">
        <slot />
    </div>

</div> 