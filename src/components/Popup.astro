---
const {id, title, background} = Astro.props;
---

<div id={id} class="popup fixed top-1/4 left-1/3 z-50 w-80 rounded-xl shadow-xl bg-cover bg-center" style={`background-image: url(${background})`}>
    <div class="popup-handle cursor-move rounded-t-xl px-4 py-2 flex justify-between items-center">
        <span>{title}</span>
        <button class="popup-close">
            <img src="/assets/yt-icon.png" alt="close" class="w-4 h-4"/>
        </button>
    </div>

    <div class="p-4">
        <slot />
    </div>

</div> 